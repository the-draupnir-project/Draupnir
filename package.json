{
  "name": "@the-draupnir-project/monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-draupnir-project/Draupnir.git"
  },
  "author": "Gnuxie",
  "license": "AFL-3.0",
  "bugs": {
    "url": "https://github.com/the-draupnir-project/Draupnir/issues"
  },
  "homepage": "https://github.com/the-draupnir-project/Draupnir#readme",
  "scripts": {
    "build": "tsc -b && npm run -ws build:assets --if-present",
    "build:all": "tsc -b tsconfig.all.json && -ws build:assets --if-present",
    "build:clean": "tsc -b --clean",
    "lint": "eslint --cache 'packages/**/*{ts, tsx}' && prettier --cache --ignore-unknown --check apps packages README.md CHANGELOG.md"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@the-draupnir-project/tsconfig": "^0.1.0",
    "eslint": "^9.39.3",
    "prettier": "^3.3.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "overrides": {
    "@vector-im/matrix-bot-sdk": "0.7.1-element.6"
  }
}
