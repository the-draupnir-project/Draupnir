{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declarationDir": "dist",
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react",
    "jsxFactory": "DeadDocumentJSX.JSXFactory"
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__",
    "**/*.test.tsx",
    "**/*.spec.tsx"
  ]
}
